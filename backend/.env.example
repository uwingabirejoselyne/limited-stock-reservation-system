NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/limited_stock_db"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Reservation TTL in minutes
RESERVATION_TTL_MINUTES=5

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
